  },
  "dependencies": {
    "tiged": "^2.12.7",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.35"
  },
  "scripts": {
    "build": "tsx ./scripts/build.ts",
    "test": "vitest --run -c src/tests/vitest.config.ts"
  }
}
