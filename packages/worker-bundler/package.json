    "resolve.exports": "^2.0.3",
    "semver": "^7.8.5",
    "smol-toml": "^1.7.0",
    "sucrase": "^3.35.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260629.1",
    "@types/semver": "^7.7.1",
    "esbuild": "^0.28.1",
    "tsdown": "^0.22.3"
  },
  "engines": {
    "node": ">=22"
  }
}
