{
  "name": "@cloudflare/shell",
  "version": "0.0.2",
  "description": "Runtime-agnostic bash interpreter with pluggable backends",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "directory": "packages/shell",
    "type": "git",
    "url": "git+https://github.com/cloudflare/agents.git"
  },
  "bugs": {
    "url": "https://github.com/cloudflare/agents/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./workers": {
      "types": "./dist/workers.d.ts",
      "import": "./dist/workers.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./embedded": {
      "types": "./dist/embedded.d.ts",
      "import": "./dist/embedded.js"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsx ./scripts/build.ts",
    "test": "vitest run",
    "test:workers": "vitest run --config src/workers-tests/vitest.config.ts",
    "test:node": "vitest run --config src/node-tests/vitest.config.ts",
    "test:browser": "vitest run --config src/browser-tests/vitest.config.ts",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "diff": "^8.0.3",
    "file-type": "^21.3.3",
    "minimatch": "^10.0.1",
    "re2js": "^1.2.2",
    "sprintf-js": "^1.1.3"
  },
  "peerDependencies": {
    "better-sqlite3": ">=11",
    "pyodide": ">=0.26",
    "quickjs-emscripten": ">=0.29",
    "turndown": ">=7"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "pyodide": {
      "optional": true
    },
    "quickjs-emscripten": {
      "optional": true
    },
    "turndown": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/turndown": "^5.0.6",
    "better-sqlite3": "^12.6.2",
    "pyodide": "^0.29.3",
    "quickjs-emscripten": "^0.32.0",
    "tsdown": "^0.21.1",
    "turndown": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "3.2.4"
  }
}
