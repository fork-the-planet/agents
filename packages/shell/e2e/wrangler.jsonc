{
  "name": "shell-e2e",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "main": "worker.ts",
  "durable_objects": {
    "bindings": [
      {
        "class_name": "ShellDO",
        "name": "SHELL_DO"
      }
    ]
  },
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
  "migrations": [
    {
      "new_sqlite_classes": ["ShellDO"],
      "tag": "v1"
    }
  ]
}
