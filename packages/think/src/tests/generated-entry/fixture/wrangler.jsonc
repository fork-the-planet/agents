{
  "compatibility_date": "2026-06-11",
  "compatibility_flags": ["nodejs_compat"],
  "main": "entry.ts",
  "durable_objects": {
    "bindings": [
      {
        "class_name": "ThinkAgent_Support",
        "name": "SupportDirectory"
      },
      {
        "class_name": "ThinkAgent_Sales",
        "name": "SalesDirectory"
      },
      // Test-only bindings: vitest-pool-workers needs facet classes listed
      // here even though production Think apps get facets from Worker exports.
      {
        "class_name": "ThinkSubAgent_Support_Researcher",
        "name": "ThinkSubAgent_Support_Researcher"
      },
      {
        "class_name": "ThinkSubAgent_Sales_Researcher",
        "name": "ThinkSubAgent_Sales_Researcher"
      },
      {
        "class_name": "ThinkSubAgent_Sales_Analyst",
        "name": "ThinkSubAgent_Sales_Analyst"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": [
        "ThinkAgent_Sales",
        "ThinkAgent_Support",
        "ThinkSubAgent_Sales_Analyst"
      ],
      "tag": "v1"
    }
  ],
  "assets": {
    "run_worker_first": ["/api/agents/*"]
  }
}
