{
  "name": "think-e2e-test",
  "main": "worker.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "ai": { "binding": "AI", "remote": true },
  "define": {
    "__filename": "'index.ts'"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "TestAssistant",
        "class_name": "TestAssistant"
      },
      {
        "name": "ThinkRecoveryE2EAgent",
        "class_name": "ThinkRecoveryE2EAgent"
      },
      {
        "name": "ThinkRecoveryHelperParent",
        "class_name": "ThinkRecoveryHelperParent"
      },
      // Test-harness-only binding: production only needs to export this
      // facet class, but vitest-pool-workers needs it here for ctx.exports.
      {
        "name": "ThinkRecoveryHelperAgent",
        "class_name": "ThinkRecoveryHelperAgent"
      },
      {
        "name": "ThinkToolRollbackE2EAgent",
        "class_name": "ThinkToolRollbackE2EAgent"
      },
      {
        "name": "ThinkPersistFalseE2EAgent",
        "class_name": "ThinkPersistFalseE2EAgent"
      },
      {
        "name": "ThinkStallRecoveryE2EAgent",
        "class_name": "ThinkStallRecoveryE2EAgent"
      },
      {
        "name": "ThinkTaskParentE2EAgent",
        "class_name": "ThinkTaskParentE2EAgent"
      },
      {
        "name": "ThinkAgentToolNaturalParentE2EAgent",
        "class_name": "ThinkAgentToolNaturalParentE2EAgent"
      },
      // Test-harness-only binding: production only needs to export the child
      // facet class, but vitest-pool-workers needs it here for ctx.exports.
      {
        "name": "ThinkSlowChildE2EAgent",
        "class_name": "ThinkSlowChildE2EAgent"
      },
      {
        "name": "ThinkSlowChildParentE2EAgent",
        "class_name": "ThinkSlowChildParentE2EAgent"
      },
      {
        "name": "TestStructuredAgent",
        "class_name": "TestStructuredAgent"
      },
      {
        "name": "ThinkContextOverflowE2EAgent",
        "class_name": "ThinkContextOverflowE2EAgent"
      },
      {
        "name": "ThinkSubmissionRecoveryE2EAgent",
        "class_name": "ThinkSubmissionRecoveryE2EAgent"
      },
      {
        "name": "ThinkMessengerRecoveryE2EAgent",
        "class_name": "ThinkMessengerRecoveryE2EAgent"
      },
      {
        "name": "ThinkWorkflowRecoveryE2EAgent",
        "class_name": "ThinkWorkflowRecoveryE2EAgent"
      }
    ]
  },
  "workflows": [
    {
      "name": "STEP_PROMPT_WORKFLOW",
      "binding": "STEP_PROMPT_WORKFLOW",
      "class_name": "StepPromptWorkflow"
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "TestAssistant",
        "ThinkRecoveryE2EAgent",
        "ThinkRecoveryHelperParent"
      ]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["ThinkToolRollbackE2EAgent"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["ThinkTaskParentE2EAgent"]
    },
    {
      "tag": "v4",
      "new_sqlite_classes": ["ThinkAgentToolNaturalParentE2EAgent"]
    },
    {
      "tag": "v5",
      "new_sqlite_classes": ["ThinkPersistFalseE2EAgent"]
    },
    {
      "tag": "v6",
      "new_sqlite_classes": ["ThinkStallRecoveryE2EAgent"]
    },
    {
      "tag": "v7",
      "new_sqlite_classes": [
        "ThinkSlowChildParentE2EAgent",
        "ThinkSlowChildE2EAgent"
      ]
    },
    {
      "tag": "v8",
      "new_sqlite_classes": ["TestStructuredAgent"]
    },
    {
      "tag": "v9",
      "new_sqlite_classes": ["ThinkContextOverflowE2EAgent"]
    },
    {
      "tag": "v10",
      "new_sqlite_classes": ["ThinkSubmissionRecoveryE2EAgent"]
    },
    {
      "tag": "v11",
      "new_sqlite_classes": ["ThinkMessengerRecoveryE2EAgent"]
    },
    {
      "tag": "v12",
      "new_sqlite_classes": ["ThinkWorkflowRecoveryE2EAgent"]
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "think-e2e-test-workspace"
    }
  ]
}
