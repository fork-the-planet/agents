{
  "name": "fiber-e2e-test",
  "main": "worker.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "RunFiberTestAgent",
        "class_name": "RunFiberTestAgent"
      },
      {
        "name": "SubAgentFiberParent",
        "class_name": "SubAgentFiberParent"
      },
      // Test-harness-only binding: production only needs to export this
      // facet class, but vitest-pool-workers needs it here for ctx.exports.
      {
        "name": "SubAgentFiberChild",
        "class_name": "SubAgentFiberChild"
      },
      {
        "name": "PoisonRowAgent",
        "class_name": "PoisonRowAgent"
      },
      {
        "name": "ScanDeadlineAgent",
        "class_name": "ScanDeadlineAgent"
      },
      {
        "name": "ConcurrentFiberAgent",
        "class_name": "ConcurrentFiberAgent"
      },
      {
        "name": "PoisonBackoffAgent",
        "class_name": "PoisonBackoffAgent"
      },
      {
        "name": "FacetRecoveryParent",
        "class_name": "FacetRecoveryParent"
      },
      // Test-harness-only binding (facet child): registered for ctx.exports,
      // not migrated as its own SQLite class (mirrors SubAgentFiberChild).
      {
        "name": "FacetRecoveryChild",
        "class_name": "FacetRecoveryChild"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RunFiberTestAgent", "SubAgentFiberParent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": [
        "PoisonRowAgent",
        "ScanDeadlineAgent",
        "ConcurrentFiberAgent"
      ]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["PoisonBackoffAgent", "FacetRecoveryParent"]
    }
  ]
}
