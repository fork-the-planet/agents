# GitHub OAuth credentials for the assistant example.
# Create a GitHub OAuth App at https://github.com/settings/developers
# and fill in the values below before running `npm start`.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional local-dev escape hatch: skip GitHub OAuth and act as this user.
# Put it in .env.local (gitignored) rather than here. Never set in production.
# DEV_USER=yourname
