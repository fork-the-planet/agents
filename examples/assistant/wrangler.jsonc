{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "think-assistant",
  "ai": { "binding": "AI", "remote": true },
  // Browser Rendering for the execute tool's `cdp.*` connector — the agent
  // one-liner picks up `env.BROWSER` automatically.
  "browser": { "binding": "BROWSER" },
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "not_found_handling": "single-page-application",
    // Only the OAuth and auth-gated chat routes are handled by the Worker.
    // `/agents/*` is deliberately NOT routed here — the only way to reach
    // MyAssistant is through `/chat*` after the Worker verifies the
    // authenticated GitHub user, so the browser cannot address another
    // user's DO directly by name.
    "run_worker_first": ["/auth/*", "/chat", "/chat/*"]
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "ThinkAgent_Assistant",
        "name": "AssistantDirectory"
      }
    ]
  },
  "worker_loaders": [{ "binding": "LOADER" }],
  "main": "virtual:think/entry",
  "migrations": [
    {
      "new_sqlite_classes": ["ThinkAgent_Assistant"],
      "tag": "v1"
    }
  ],
  "vars": {
    // Optional local-dev escape hatch (see src/server.ts): set DEV_USER in
    // .env.local to skip GitHub OAuth and act as that user. Blank = disabled.
    // NOTE: no `secrets.required` allowlist here — it would stop optional
    // entries like DEV_USER from being read out of .env/.env.local. The
    // server throws a clear error when the GitHub secrets are missing.
    "DEV_USER": ""
  }
}
