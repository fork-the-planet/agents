{
  "name": "@cloudflare/agents-agents-as-tools-example",
  "description": "Agents-as-tools: a Think chat dispatches helper sub-agents during a turn whose lifecycle events stream live into the chat UI.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite dev",
    "deploy": "vite build && wrangler deploy",
    "test": "vitest --run --config src/tests/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "types": "wrangler types env.d.ts --include-runtime false"
  },
  "dependencies": {
    "@cloudflare/kumo": "^2.6.0",
    "@cloudflare/think": "*",
    "@phosphor-icons/react": "^2.1.10",
    "@streamdown/code": "^1.1.1",
    "agents": "*",
    "ai": "^6.0.202",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "streamdown": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@cloudflare/workers-types": "^4.20260625.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "wrangler": "^4.105.0"
  }
}
