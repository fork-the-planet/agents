coverage
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# dotenv environment variable files
.env
.env.*
!.env.example

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# build output
dist
.output

# Vite files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/

.wrangler
.DS_Store

# Churn run artifacts (timelines, verdicts, captured server logs)
scripts/runs/
