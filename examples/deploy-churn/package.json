{
  "name": "@cloudflare/agents-deploy-churn-example",
  "description": "Reliability harness: drive a durable chat turn while firing repeated real wrangler deploys mid-turn to observe recovery behavior",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "start": "vite dev",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "churn": "tsx scripts/churn.ts",
    "rollback": "tsx scripts/deploy-rollback.ts",
    "tail": "tsx scripts/tail.ts",
    "types": "wrangler types env.d.ts --include-runtime false"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.82",
    "@cloudflare/ai-chat": "*",
    "@cloudflare/kumo": "^2.5.1",
    "@cloudflare/think": "*",
    "@phosphor-icons/react": "^2.1.10",
    "agents": "*",
    "ai": "^6.0.199",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "workers-ai-provider": "^3.1.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@cloudflare/workers-types": "^4.20260609.1",
    "@tailwindcss/vite": "^4",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "partysocket": "1.1.19",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.99.0"
  }
}
