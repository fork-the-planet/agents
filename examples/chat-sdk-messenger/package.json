{
  "name": "@cloudflare/agents-chat-sdk-messenger",
  "description": "Chat SDK messenger ingress with Agent subagent-backed state",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "start": "vite dev",
    "deploy": "vite build && wrangler deploy",
    "test": "vitest --run --config src/tests/vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "types": "wrangler types env.d.ts --include-runtime false"
  },
  "dependencies": {
    "@chat-adapter/telegram": "^4.31.0",
    "@cloudflare/kumo": "^2.6.0",
    "@cloudflare/think": "*",
    "@phosphor-icons/react": "^2.1.10",
    "agents": "*",
    "ai": "^6.0.202",
    "chat": "^4.31.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@cloudflare/workers-types": "^4.20260629.1",
    "@tailwindcss/vite": "^4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "wrangler": "^4.105.0"
  }
}
