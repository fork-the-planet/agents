{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "think-business-workflow-starter",
  "main": "virtual:think/entry",
  "compatibility_date": "2026-06-11",
  "compatibility_flags": ["nodejs_compat"],
  "ai": { "binding": "AI" },
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/messengers/*", "/__think/*"]
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "ThinkAgent_Operations",
        "name": "ThinkAgent_Operations"
      }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ThinkAgent_Operations"] }
  ]
}
