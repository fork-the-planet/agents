{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "chat-recovery-probe",
  "main": "src/server.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "head_sampling_rate": 1
    }
  },
  "durable_objects": {
    "bindings": [{ "name": "ProbeAgent", "class_name": "ProbeAgent" }]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ProbeAgent"]
    }
  ]
}
