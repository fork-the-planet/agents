{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "issue-1691-live",
  "main": "src/server.ts",
  "compatibility_date": "2026-06-11",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "LiveChatAgent",
        "class_name": "LiveChatAgent"
      },
      {
        "name": "LiveThinkAgent",
        "class_name": "LiveThinkAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["LiveChatAgent", "LiveThinkAgent"]
    }
  ],
  "vars": {
    "LLM_PROVIDER": "workers-ai"
  },
  "secrets": {
    "required": ["OPENAI_API_KEY", "ANTHROPIC_API_KEY"]
  }
}
